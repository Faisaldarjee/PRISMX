# ───────────────────────────────────────────────────────────────────
#                   PRISM LOCAL & PRODUCTION SETUP
# ───────────────────────────────────────────────────────────────────
# Copy this file to ".env" in local development.
# NEVER commit your credentials to source control.

# ── 1. GOOGLE GEMINI API KEY ──────────────────────────────────────
# Obtain your free API key from Google AI Studio:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── 2. SUPABASE APP CREDENTIALS ───────────────────────────────────
# Set up a Supabase project and get your API credentials from Project Settings -> API.
# Note: Variables prefixed with 'VITE_' are automatically injected into the browser build.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── 3. SUPABASE SERVICE ROLE CONFIG (Keep server-side environment variables secure)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-auth

# ── 4. ADMINISTRATIVE BACKUP KEY ──────────────────────────────────
# Authentication key for streaming backups from Cloud Run to local machine.
# Keep this secure. Use it in 'X-Admin-Key' header when calling '/api/admin/export-db'
ADMIN_EXPORT_KEY=your-secure-admin-backup-key-here

# ── 5. HOSTING & COMPILER VARIABLES ───────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

